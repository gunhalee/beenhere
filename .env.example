# Supabase (로컬: .env.local 에 복사 후 값 채우기)
# Vercel: Project → Settings → Environment Variables 에 동일 키로 등록
#   - Production / Preview / Development 필요에 맞게 선택
#   - SUPABASE_SERVICE_ROLE_KEY 는 서버 전용(절대 클라이언트에 노출 금지)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Auth (대시보드 Authentication → URL Configuration)
# Site URL: 배포 URL 예) https://your-app.vercel.app
# Redirect URLs 에 추가: https://your-app.vercel.app/auth/callback
# (로컬 개발 시) http://localhost:3000/auth/callback
